# fe-api-tracer 환경 설정 예시
# 이 파일을 .env.api-tracer 로 복사하고 값을 수정하세요.
# .gitignore 에 .env.api-tracer 를 추가하는 것을 권장합니다.

# 출력 경로 (기본값: docs/api.html)
# FE_API_TRACER_OUTPUT=docs/api.html

# 프레임워크 프리셋 (auto | nextjs-pages | nextjs-app | nuxt | vue | react)
# FE_API_TRACER_FRAMEWORK=nextjs-pages

# API 파일 디렉토리 (쉼표 구분, glob 지원)
# FE_API_TRACER_API_DIRS=src/domain/**/api,src/shared/api

# HTTP 클라이언트 패턴 (쉼표 구분)
# FE_API_TRACER_HTTP_PATTERNS=this.http,this.axios,apiClient

# path alias JSON (tsconfig.json 에서 자동 읽으므로 보통 불필요)
# FE_API_TRACER_ALIAS={"@/":"./src/","@domain/":"./src/domain/"}

# 추적 제외 심볼 (DI 컨테이너 등, 쉼표 구분)
# FE_API_TRACER_TRACE_EXCLUDE=Container,Mapper,Injectable

# 공유 디렉토리 (2단계 추적에서 제외, 쉼표 구분)
# FE_API_TRACER_SHARED_DIRS=src/shared
