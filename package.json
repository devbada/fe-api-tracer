{
  "name": "fe-api-tracer",
  "version": "1.0.0",
  "description": "프론트엔드 API 문서 자동 생성 도구 — 서버 라우트, 클라이언트 호출, 사용처 추적",
  "main": "dist/scripts/generate-api-docs.js",
  "types": "dist/scripts/generate-api-docs.d.ts",
  "bin": {
    "fe-api-tracer": "./bin/cli.js",
    "scaffold-jsdoc": "./bin/scaffold-jsdoc.js",
    "diff-api": "./bin/diff-api.js"
  },
  "scripts": {
    "build": "tsc",
    "generate": "ts-node scripts/generate-api-docs.ts",
    "generate:watch": "ts-node scripts/generate-api-docs.ts --watch",
    "scaffold": "ts-node scripts/scaffold-jsdoc.ts",
    "diff": "ts-node scripts/diff-api.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "api",
    "documentation",
    "tracer",
    "nextjs",
    "nuxt",
    "react",
    "vue",
    "openapi",
    "postman",
    "ast"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "vitest": "^1.0.0",
    "@types/node": "^18.0.0"
  },
  "dependencies": {
    "ts-morph": "^20.0.0",
    "dotenv": "^16.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist/",
    "bin/",
    "config.ts",
    "README.md"
  ]
}
